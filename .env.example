# =============================================================================
# Docloom environment variables
# Copy to .env.local for local development. Never commit real credentials.
# =============================================================================

# --- App ---
# Canonical URL (no trailing slash). Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional override used by Better Auth (defaults to NEXT_PUBLIC_APP_URL)
# BETTER_AUTH_URL=http://localhost:3000

# --- Neon Postgres ---
# Pooled connection — use for application queries on Vercel Functions
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct / unpooled connection — use for migrations (drizzle-kit / db:migrate)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Optional: document your Neon primary region (e.g. aws-us-east-1)
# NEON_REGION=aws-us-east-1
# Optional structured-log threshold for measured server operations
# SLOW_OPERATION_MS=250

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# --- Transactional email (Resend) ---
# Leave unset in local dev to log emails to the console
RESEND_API_KEY=
EMAIL_FROM=Docloom <noreply@your-domain.com>

# --- Vercel Blob ---
# Created automatically when you attach a Blob store in the Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# --- Cron protection ---
# Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace-with-random-cron-secret

# --- Slack integration (optional — features disable gracefully) ---
# Create the app from slack-app-manifest.json at https://api.slack.com/apps
# Credentials live under "Basic Information" → "App Credentials"
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# 32-byte key for encrypting Slack bot tokens at rest.
# Generate with: openssl rand -base64 32
SLACK_TOKEN_ENCRYPTION_KEY=
# Test/mock override for the Slack API base URL (leave unset in production)
# SLACK_API_BASE=https://slack.com/api

# --- Optional AI for the @docloom Slack assistant ---
# Anthropic improves conversational keyword extraction.
# OpenAI also enables paragraph-level "find docs like this…" semantic search
# via text-embedding-3-small. Bounded paragraph/query text is sent to OpenAI.
# Without either key, a deterministic lexical fallback remains available.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Seed (local only) ---
# SEED_USER_EMAIL=demo@docloom.local
# SEED_USER_PASSWORD=DocloomDemo123!
# SEED_ALLOW_PRODUCTION=false

# --- Vercel (set automatically on Vercel) ---
# VERCEL_ENV=preview|production
# NEXT_PUBLIC_VERCEL_ENV=preview|production
# VERCEL_URL=
# VERCEL_REGION=iad1
